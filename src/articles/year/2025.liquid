---
layout: generic
title: Articles by Year
year: 2025
description: All {{ year }}posts in reverse chronological order.
---

<p>wassup</p>

<ul class="posts">
  {% for post in collections.posts | postsForYear({{year}} }}) %}
  <li>
    <h4>
      <a href="{{post.url}}" style="cursor: pointer">{{ post.data.title }}</a>
    </h4>
    Posted {%- if post.data.timestamp %}
      {{ post.data.timestamp | readableTimestamp }}
    {%- else %}
      {{ post.date | readableDate }}
    {%- endif %}&nbsp;
    {% if post.data.categories.length > 0 %}
      in
    {% for cat in post.data.categories %}
    <a href="/categories/{{ cat | slugify }}">{{ cat }}</a>
    {%- unless forloop.last %},
    {% endunless %}
    {% endfor %}
    {% endif %}
    <br />
    {% if post.data.description %}
    {% include 'generated.html' %}
    {% else %}
    {% excerpt post %}
    {% endif %}
  </li>
  {% endfor %}

</ul>